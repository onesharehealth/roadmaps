{
  "extends": "./tsconfig.json",
  "include": ["vite.config.ts"],
  "exclude": ["node_modules", "build"],
  "files": ["env-required.ts"],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true
  }
}
