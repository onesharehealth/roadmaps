{

  "compilerOptions": {

    "target": "ES2022",

    "lib": ["DOM", "DOM.Iterable", "ES2022"],

    "module": "ESNext",

    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "strict": true,

    "skipLibCheck": true,

    "noEmit": true,

    "isolatedModules": true,

    "resolveJsonModule": true,

    "allowJs": true,

    "types": ["@cloudflare/workers-types", "vite/client"],

    "baseUrl": ".",

    "paths": {

      "~/*": ["./app/*"],

      "roadmaps-agents": ["./roadmaps-agents/index.ts"],

      "roadmaps-agents/schemas": ["./roadmaps-agents/schemas.ts"],

      "utils": ["./packages/utils/index.ts"],

      "utils/*": ["./packages/utils/*"],

      "websockets": ["./packages/websockets/index.ts"],

      "websockets/*": ["./packages/websockets/*"],

      "email": ["./packages/email/index.ts"]

    },

    "rootDirs": [".", "./.react-router/types"]

  },

  "include": [

    "app/**/*",

    "workers/**/*",

    "roadmaps-agents/**/*",

    "packages/**/*",

    ".react-router/types/**/*"

  ]

}

